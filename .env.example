# Copy this file to .env and fill in the values you want to pre-configure.

# OpenAI or OpenAI-compatible defaults
FORGETUNE_OPENAI_BASE_URL=https://api.openai.com
FORGETUNE_OPENAI_API_KEY=
FORGETUNE_OPENAI_ORGANIZATION=
FORGETUNE_OPENAI_PROJECT=
FORGETUNE_OPENAI_MODEL=

# Optional separate defaults for non-OpenAI OpenAI-compatible gateways
FORGETUNE_OPENAI_COMPATIBLE_BASE_URL=
FORGETUNE_OPENAI_COMPATIBLE_API_KEY=
FORGETUNE_OPENAI_COMPATIBLE_ORGANIZATION=
FORGETUNE_OPENAI_COMPATIBLE_PROJECT=
FORGETUNE_OPENAI_COMPATIBLE_MODEL=

# Ollama defaults
FORGETUNE_OLLAMA_BASE_URL=http://host.docker.internal:11434
FORGETUNE_OLLAMA_MODEL=

# GitHub import defaults
FORGETUNE_GITHUB_BASE_URL=https://api.github.com
FORGETUNE_GITHUB_TOKEN=
FORGETUNE_GITHUB_REPOSITORY=

# External acquisition services
FORGETUNE_SEARXNG_BASE_URL=http://localhost:8080
FORGETUNE_CRAWLER_SERVICE_URL=

# Optional for the bundled SearxNG container
SEARXNG_PUBLIC_BASE_URL=http://localhost:8080/